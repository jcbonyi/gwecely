# Gwecely — environment variables
# Copy to .env and fill in values

# Clerk app: app_3FgaIn4JzTNpfqohyFhzM3sXy8I
# After `clerk auth login`, run: clerk link --app app_3FgaIn4JzTNpfqohyFhzM3sXy8I && clerk env pull
CLERK_SECRET_KEY=sk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Comma-separated emails allowed to access /admin (server + optional client check)
CLERK_ADMIN_EMAILS=info@gwecely.co.ke,jcbonyi@gmail.com
VITE_CLERK_ADMIN_EMAILS=info@gwecely.co.ke,jcbonyi@gmail.com

# --- Production split deploy (Vercel frontend + API host) ---
# Vercel server-side proxy — set this on Vercel (no rebuild needed when changed)
API_URL=https://gwecely-api.onrender.com
# Optional — call API directly from the browser instead of the Vercel proxy
VITE_API_URL=
# Frontend origin for API CORS (set on the API host)
CLIENT_URL=https://gwecely.vercel.app
# Extra allowed origins, comma-separated (optional)
CORS_ORIGINS=

# --- Cloudinary (https://cloudinary.com) ---
# API host (Render) — for signed uploads & server-side fallback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Vercel frontend — unsigned upload preset (fastest; no API hop). In Cloudinary: Settings → Upload → Add upload preset → Signing mode: Unsigned
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Database (optional — defaults to ./data/gwecely.db) ---
DATABASE_PATH=./data/gwecely.db

# --- M-Pesa Daraja (optional) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=

# --- Server ---
PORT=3000
API_PORT=3001
